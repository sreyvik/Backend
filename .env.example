# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
APP_NAME="Chomnuoy System"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000
FRONTEND_URL=http://localhost:5173

# =============================================================================
# ABA PAYWAY
# =============================================================================
ABA_ENV=sandbox
ABA_BASE_URL=
ABA_MERCHANT_ID=
ABA_API_KEY=
ABA_PUBLIC_KEY=
ABA_API_URL=
ABA_GENERATE_QR_URL=
ABA_CHECK_TRANSACTION_URL=
ABA_TRANSACTION_DETAIL_URL=
ABA_PAYMENT_OPTION=abapay_khqr
ABA_CURRENCY=USD
ABA_RETURN_URL=${APP_URL}/api/aba-payway/callback
ABA_CALLBACK_URL=${APP_URL}/api/aba-payway/callback
ABA_CANCEL_URL=${FRONTEND_URL}/organizations
ABA_CONTINUE_SUCCESS_URL=${FRONTEND_URL}/donations/view-detail

# =============================================================================
# BAKONG KHQR
# =============================================================================
BAKONG_API_URL=https://api-bakong.nbc.gov.kh
BAKONG_TOKEN=
BAKONG_MERCHANT_ID=
BAKONG_MERCHANT_NAME="Chomnuoy System"
BAKONG_MERCHANT_CITY="Phnom Penh"
BAKONG_ACQUIRING_BANK=
BAKONG_CURRENCY=USD

# Optional fallback static KHQR
BAKONG_STATIC_QR_IMAGE=
BAKONG_STATIC_QR_STRING=
BAKONG_STATIC_QR_DEEPLINK=
BAKONG_STATIC_QR_NAME="Bakong KHQR"

# =============================================================================
# LOGGING
# =============================================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# DATABASE (MySQL)
# =============================================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=chomnuoy_system
DB_USERNAME=root
DB_PASSWORD= vik123
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# =============================================================================
# CACHE & SESSION
# =============================================================================
CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# =============================================================================
# QUEUE & BROADCAST
# =============================================================================
QUEUE_CONNECTION=sync
BROADCAST_DRIVER=log

# =============================================================================
# FILESYSTEM
# =============================================================================
FILESYSTEM_DISK=local

# =============================================================================
# API RATE LIMITING
# =============================================================================
API_RATE_LIMIT_PER_MINUTE=600

# =============================================================================
# REDIS (Optional - for production caching/sessions)
# =============================================================================
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================================================
# MAIL (SMTP Configuration)
# =============================================================================
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@chomnuoy.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# AWS S3 (Optional - for file storage)
# =============================================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =============================================================================
# PUSHER (Optional - for real-time features)
# =============================================================================
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# =============================================================================
# VITE (Frontend build variables)
# =============================================================================
VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# =============================================================================
# SOCIAL AUTHENTICATION
# =============================================================================
# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback

# Facebook OAuth 2.0
# Get credentials from: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=http://127.0.0.1:8000/api/auth/facebook/callback
